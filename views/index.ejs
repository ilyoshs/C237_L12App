<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <title>Welcome to studypurr</title>

    <style>
        body {
            background: url('/images/bg.png') no-repeat center center fixed;
            background-size: cover;

            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .welcome-card {
            background: rgba(255, 255, 255, 0.9);
            padding: 40px;
            border-radius: 20px;
            max-width: 500px;
        }

        .btn-enter {
            background-color: #e1afc3;
            color: white;
            border: none;
        }

        .btn-enter:hover {
            background-color: #d495b0;
            color: white;
        }
    </style>

</head>

<body>

    <div class="container text-center">
        <div class="welcome-card mx-auto">

            <h1 class="fw-semibold mb-2" style="color: #e1afc3;">
                Hello And Welcome!
            </h1>

            <p class="text-secondary mb-4 small">
                "Yawn... Welcome back, hooman! Ready to study together?"
            </p>

            <a href="/dashboard" class="btn btn-enter btn-lg w-53 shadow-sm">
                Enter Study Space &rarr;
            </a><br>
            <img src="/images/cat.png" alt="Happy Cat" class="img-fluid mt-4" style="max-width: 300px;">

        </div>
    </div>

</body>

</html>