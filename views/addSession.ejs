<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log a session</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<style>
    body {
        background-color: #fffafc;
        color: #e1afc3;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
    }

    /* JOURNAL CONTAINER CARD */
    .journal-card {
        background-color: white;
        border: 2px solid #e1afc3;
        border-radius: 20px;
        padding: 30px;
    }

    .section-title {
        color: #e1afc3;
        font-weight: 700;
        margin: 0;
    }
</style>

<body>
    <%- include ('partials/navbar.ejs') %>
        <div class="container mt-3">
            <h2 class="mb-4" style="color: #e1afc3;">+ Log a Session</h2>

            <form action="/addSession" method="POST">
                <div class="mb-3 mt-3">
                    <label for="name">Subject:</label>
                    <input type="text" class="form-control" id="name" placeholder="Enter subject" name="name">
                </div>
                <div class="mb-3 mt-3">
                    <label for="location">Duration:</label>
                    <input type="text" class="form-control" id="location" placeholder="Enter duration" name="location">
                </div>

                <div class="mb-3 mt-3">
                    <label for="mood">Mood/Notes:</label>
                    <textarea class="form-control" id="mood" placeholder="e.g., Tired but producctive..." name="mood"
                        rows="3"></textarea>
                </div>

                <div class="mt-4 border-top pt-3 d-flex gap-2">
                    <button type="submit" class="btn text-white px-4" style="background-color: #e1afc3;">
                        Submit
                    </button>

                    <a href="/dashboard" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
</body>

</html>